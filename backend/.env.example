PORT=3000
NODE_ENV=development

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=stock_driver_system
DB_USER=root
DB_PASSWORD=
DB_SSL=false

JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=1d

# Comma-separated origins allowed to call the API in production.
# Example: https://inventory-frontend.onrender.com,https://www.example.com
CORS_ORIGIN=http://localhost:5173
CORS_ALLOW_NO_ORIGIN=false
TRUST_PROXY=false
